# === Server ===
PORT=8080

# === MongoDB ===
MONGO_URI=mongodb://localhost:27017/nomie

# === JWT ===
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# === Agent Orchestrator ===
ORCHESTRATOR_URL=http://localhost:8081

# === Internal Security ===
# Shared secret used to authenticate callbacks from the Orchestrator
INTERNAL_SECRET=change_this_internal_secret

# === Node Environment ===
NODE_ENV=development
