# === Server ===
PORT=8080

# === MongoDB ===
# Local dev: mongodb://localhost:27017/nomie
# Docker:    mongodb://mongodb:27017/nomie  (use service name, see .env.docker)
MONGO_URI=mongodb://localhost:27017/nomie

# === JWT ===
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# === CORS ===
CORS_ORIGIN=http://localhost:3000

# === Node Environment ===
NODE_ENV=development
